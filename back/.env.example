# ============================================================================
# Smart Logistics Backend — Environment Configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# ============================================================================

# --- Security ---
SECRET_KEY=change-me-to-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- Database (Postgres) ---
DATABASE_URL=postgresql://postgres:postgres@db/smart_logistics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=smart_logistics

# --- Redis (rate limiting, cache) ---
REDIS_URL=redis://redis:6379/0

# --- External APIs (all optional) ---
# Endpoints that need these fail at request time with a clear error;
# the app boots fine without them. Leave blank if you don't use them.
TRAFFIC_API_KEY=
TRAFFIC_API_URL=https://maps.googleapis.com/maps/api/distancematrix/json
WEATHER_API_KEY=
WEATHER_API_URL=https://api.openweathermap.org/data/3.0/onecall

# --- ML Model Paths ---
ROUTE_MODEL_PATH=models/route_model.pkl
INVENTORY_MODEL_PATH=models/inventory_model.pkl

# --- MLflow (experiment tracking & patent audit) ---
MLFLOW_TRACKING_URI=http://mlflow:5000

# --- Notifications (optional) ---
SLACK_BOT_TOKEN=

# --- LLM (phase 4, optional for now) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
